{
  "info": {
    "name": "Currency Converter API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "jwtToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] } }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Alex\",\n  \"email\": \"alex@example.com\",\n  \"password\": \"password123\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"alex@example.com\",\n  \"password\": \"password123\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
      }
    },
    {
      "name": "Profile",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api", "auth", "profile"] }
      }
    },
    {
      "name": "Convert Currency",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"amount\": 100,\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"INR\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/convert", "host": ["{{baseUrl}}"], "path": ["api", "convert"] }
      }
    },
    {
      "name": "Get History",
      "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }], "url": { "raw": "{{baseUrl}}/api/history", "host": ["{{baseUrl}}"], "path": ["api", "history"] } }
    },
    {
      "name": "Get History by ID",
      "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }], "url": { "raw": "{{baseUrl}}/api/history/1", "host": ["{{baseUrl}}"], "path": ["api", "history", "1"] } }
    },
    {
      "name": "Create History",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"amount\": 50,\n  \"fromCurrency\": \"EUR\",\n  \"toCurrency\": \"USD\",\n  \"exchangeRate\": 1.08,\n  \"convertedAmount\": 54,\n  \"note\": \"Trip plan\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/history", "host": ["{{baseUrl}}"], "path": ["api", "history"] }
      }
    },
    {
      "name": "Update History",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"note\": \"Updated note\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/history/1", "host": ["{{baseUrl}}"], "path": ["api", "history", "1"] }
      }
    },
    {
      "name": "Delete History",
      "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{jwtToken}}" }], "url": { "raw": "{{baseUrl}}/api/history/1", "host": ["{{baseUrl}}"], "path": ["api", "history", "1"] } }
    },
    {
      "name": "Unauthorized Request",
      "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/history", "host": ["{{baseUrl}}"], "path": ["api", "history"] } }
    },
    {
      "name": "Google OAuth",
      "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/auth/google", "host": ["{{baseUrl}}"], "path": ["auth", "google"] } }
    }
  ]
}
